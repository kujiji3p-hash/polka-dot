# Polka Dot v1.0 - Environment Configuration
# Rename to .env and fill in your values

FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database (PostgreSQL via DBeaver)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/polka_dot_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=polka_dot_db

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
